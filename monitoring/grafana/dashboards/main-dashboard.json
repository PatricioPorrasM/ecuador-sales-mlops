{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for Ecuador Sales MLOps",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "description": "End-to-end observability for the Ecuador Sales MLOps prediction pipeline",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["mlops", "ecuador-sales", "predictions"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ecuador Sales MLOps",
  "uid": "ecuador-sales-mlops-main",
  "version": 1,
  "panels": [

    {
      "id": 1,
      "title": "Requests por Minuto — Todos los Servicios",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(web_requests_total[5m])) * 60",
          "legendFormat": "web-ui",
          "refId": "A"
        },
        {
          "expr": "sum(rate(agent_requests_total[5m])) * 60",
          "legendFormat": "ai-agent",
          "refId": "B"
        },
        {
          "expr": "sum(rate(inference_requests_total[5m])) * 60",
          "legendFormat": "ml-inference",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 2,
      "title": "Latencia de Inferencia — P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 3,
      "title": "Latencia End-to-End del Pipeline Completo — P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Medido desde que el ai-agent recibe la pregunta hasta que devuelve la respuesta final (incluye todas las llamadas LLM + ml-inference). Fuente: kafka-consumer procesando eventos agent-actions.",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(pipeline_end_to_end_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_end_to_end_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(pipeline_end_to_end_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "spanNulls": false,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 4,
      "title": "Predicciones por Provincia — Top 5",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(5, sort_desc(sum by(provincia) (requests_by_provincia_total)))",
          "legendFormat": "{{provincia}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "yellow", "value": 100 },
              { "color": "orange", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "minVizWidth": 8,
        "text": {}
      }
    },

    {
      "id": 5,
      "title": "Distribución de Valores Predichos por Provincia",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Último valor predicho de ventas societarias por provincia (USD)",
      "targets": [
        {
          "expr": "sort_desc(model_prediction_value)",
          "legendFormat": "{{provincia}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "green",  "value": 1000000 },
              { "color": "yellow", "value": 50000000 },
              { "color": "orange", "value": 200000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "valueLabel": "provincia" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": { "provincia": "Provincia", "Value": "Predicción (USD)" }
          }
        }
      ]
    },

    {
      "id": 6,
      "title": "Score de Confianza del Modelo",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Percentil 50 de la distribución de scores de confianza en la ventana reciente. RF: varianza entre árboles. XGBoost: test_r2 del entrenamiento.",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(model_confidence_score_bucket[10m])) by (le))",
          "legendFormat": "P50 Confianza",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(model_confidence_score_bucket[10m])) by (le))",
          "legendFormat": "P95 Confianza",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green",  "value": 0.75 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "text": {}
      }
    },

    {
      "id": 7,
      "title": "Kafka Consumer Lag por Topic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Lag = end_offset − current_position. Zero = consumer está al día. Actualizado cada 30 s por el consumer.",
      "targets": [
        {
          "expr": "kafka_consumer_lag",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "id": 8,
      "title": "Mensajes Kafka Consumidos por Topic (por Minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(kafka_messages_consumed_total{topic=\"user-requests\"}[5m]) * 60",
          "legendFormat": "user-requests",
          "refId": "A"
        },
        {
          "expr": "rate(kafka_messages_consumed_total{topic=\"agent-actions\"}[5m]) * 60",
          "legendFormat": "agent-actions",
          "refId": "B"
        },
        {
          "expr": "rate(kafka_messages_consumed_total{topic=\"model-responses\"}[5m]) * 60",
          "legendFormat": "model-responses",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

    {
      "id": 9,
      "title": "CPU y Memoria por Proceso",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"web-ui\"}[5m]) * 100",
          "legendFormat": "CPU % — web-ui",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"ai-agent\"}[5m]) * 100",
          "legendFormat": "CPU % — ai-agent",
          "refId": "B"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"ml-inference\"}[5m]) * 100",
          "legendFormat": "CPU % — ml-inference",
          "refId": "C"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"web-ui\"} / 1048576",
          "legendFormat": "MEM MB — web-ui",
          "refId": "D"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"ai-agent\"} / 1048576",
          "legendFormat": "MEM MB — ai-agent",
          "refId": "E"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"ml-inference\"} / 1048576",
          "legendFormat": "MEM MB — ml-inference",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "C" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "D" },
            "properties": [{ "id": "unit", "value": "decmbytes" }, { "id": "custom.axisPlacement", "value": "right" }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "E" },
            "properties": [{ "id": "unit", "value": "decmbytes" }, { "id": "custom.axisPlacement", "value": "right" }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "F" },
            "properties": [{ "id": "unit", "value": "decmbytes" }, { "id": "custom.axisPlacement", "value": "right" }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "id": 10,
      "title": "Tasa de Errores por Servicio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Proporción de requests que terminan en error. Verde = 0%. Alerta recomendada > 5%.",
      "targets": [
        {
          "expr": "sum(rate(inference_requests_total{status=\"error\"}[5m])) / sum(rate(inference_requests_total[5m]))",
          "legendFormat": "ml-inference error rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(agent_requests_total{status=\"error\"}[5m])) / sum(rate(agent_requests_total[5m]))",
          "legendFormat": "ai-agent error rate",
          "refId": "B"
        },
        {
          "expr": "sum(rate(web_requests_total{status=~\"timeout|agent_error|connection_error\"}[5m])) / sum(rate(web_requests_total[5m]))",
          "legendFormat": "web-ui error rate",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }

  ]
}
