# ══════════════════════════════════════════════════════════════════════════════
# Ecuador Sales MLOps — variables de entorno
#
# Copia este archivo a .env y rellena los valores reales:
#   cp .env.example .env
#
# NUNCA commits el archivo .env — ya está en .gitignore.
# Para CI/CD usa GitHub Secrets (ver .github/workflows/cd.yml).
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Groq — LLM provider para el ai-agent (ReAct loop)
# Obtener en: https://console.groq.com/keys
# Leído por: LiteLLM internamente cuando LITELLM_MODEL empieza con "groq/"
# ──────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# Weights & Biases — tracking de experimentos y registro de modelos
# Obtener en: https://wandb.ai/settings
# Leído por: services/model-trainer (trainer.py, compare_and_promote.py)
# ──────────────────────────────────────────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=ecuador-sales-mlops
WANDB_ENTITY=your_wandb_username_here

# ──────────────────────────────────────────────────────────────────────────────
# Kafka — broker y topics
#
# KAFKA_BOOTSTRAP_SERVERS  → nombre exacto que leen los servicios Python
# KAFKA_BROKER             → alias semántico para docker-compose / docs
#
# Dentro de Docker Compose:   kafka:9092
# Desde el host (local):      localhost:29092
# Dentro de Kubernetes:       kafka-service.streaming.svc.cluster.local:9092
# ──────────────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_BROKER=kafka:9092

KAFKA_TOPIC_USER_REQUESTS=user-requests
KAFKA_TOPIC_AGENT_ACTIONS=agent-actions
KAFKA_TOPIC_MODEL_RESPONSES=model-responses

# Configuración del consumer (kafka-consumer)
CONSUMER_GROUP=mlops-metrics-consumer
AUTO_OFFSET_RESET=latest
METRICS_PORT=8003

# ──────────────────────────────────────────────────────────────────────────────
# URLs de servicios — para desarrollo local con docker-compose
#
# ML_INFERENCE_URL / INFERENCE_SERVICE_URL  → leído por ai-agent (tools.py)
# AI_AGENT_URL / AGENT_SERVICE_URL          → leído por web-ui (app.py)
#
# Los nombres con sufijo _URL son los que lee el código Python.
# Los nombres con prefijo INFERENCE_/AGENT_ son aliases para docs y scripts.
# ──────────────────────────────────────────────────────────────────────────────
ML_INFERENCE_URL=http://ml-inference:5000
INFERENCE_SERVICE_URL=http://ml-inference:5000

AI_AGENT_URL=http://ai-agent:5001
AGENT_SERVICE_URL=http://ai-agent:5001

# Timeouts (segundos)
INFERENCE_TIMEOUT_SECS=10
AGENT_TIMEOUT_SECS=120

# ──────────────────────────────────────────────────────────────────────────────
# LLM — configuración del ai-agent
# ──────────────────────────────────────────────────────────────────────────────
LITELLM_MODEL=groq/llama3-8b-8192
AGENT_MAX_ITERATIONS=8

# ──────────────────────────────────────────────────────────────────────────────
# Datos — ruta al CSV del SRI (Ecuador)
# Leído por: ai-agent (tools.py), model-trainer (train_v1.py, train_v2.py)
# ──────────────────────────────────────────────────────────────────────────────
DATA_PATH=/app/data/Bdd_SRI_2025.csv

# ──────────────────────────────────────────────────────────────────────────────
# Modelo — rutas de salida y carga
# MODEL_DIR  → directorio donde el trainer escribe los pkl
# MODEL_PATH → ruta completa que usa ml-inference para cargar el modelo ganador
# ──────────────────────────────────────────────────────────────────────────────
MODEL_DIR=/app/models
MODEL_PATH=/app/models/model_production.pkl

# ──────────────────────────────────────────────────────────────────────────────
# Entrenamiento — auto-promoción de modelos
# Si RMSE(v2) < RMSE(v1) * PROMOTION_THRESHOLD → v2 se promueve a producción
# ──────────────────────────────────────────────────────────────────────────────
PROMOTION_THRESHOLD=0.95

# ──────────────────────────────────────────────────────────────────────────────
# Predicción — ventana temporal válida
#
# Dataset cubre ene 2020 – sep 2025 (registro 69).
# Corte: septiembre 2025. Primer mes predecible: octubre 2025.
# MAX_PREDICTION_MONTHS define hasta dónde puede predecir el agente.
# Con 12: ventana válida = oct 2025 — sep 2026.
# Leído por: services/ai-agent/tools.py (validate_prediction_date)
# ──────────────────────────────────────────────────────────────────────────────
MAX_PREDICTION_MONTHS=12
